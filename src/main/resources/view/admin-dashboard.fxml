<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.AdminDashboardController"
            prefWidth="1200"
            prefHeight="750"
            styleClass="root">

    <left>
        <VBox spacing="16" prefWidth="220" styleClass="sidebar">
            <Label text="Auction App" styleClass="sidebar-title"/>

            <Button text="Dashboard"
                    prefWidth="170"
                    styleClass="primary-button"/>

            <Button text="Refresh"
                    onAction="#handleRefresh"
                    prefWidth="170"
                    styleClass="secondary-button"/>

            <Button text="Close Expired"
                    onAction="#handleCloseExpiredAuctions"
                    prefWidth="170"
                    styleClass="secondary-button"/>

            <Button text="Logout"
                    onAction="#handleLogout"
                    prefWidth="170"
                    styleClass="danger-button"/>
        </VBox>
    </left>

    <top>
        <VBox spacing="8" style="-fx-padding: 24 24 8 24;">
            <Label text="Admin Dashboard" styleClass="page-title"/>
            <Label text="Review seller products and create auctions" styleClass="sub-title"/>
            <Label fx:id="messageLabel" styleClass="success-label"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="20" style="-fx-padding: 16 24 24 24;">

            <VBox spacing="16" prefWidth="650">

                <VBox spacing="10" styleClass="card">
                    <Label text="All Seller Products"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                    <TextArea fx:id="itemTextArea"
                              editable="false"
                              wrapText="true"
                              prefHeight="250"/>
                </VBox>

                <VBox spacing="10" styleClass="card">
                    <Label text="Auction Overview"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                    <TextArea fx:id="auctionTextArea"
                              editable="false"
                              wrapText="true"
                              prefHeight="250"/>
                </VBox>

            </VBox>

            <VBox spacing="16" prefWidth="360">

                <VBox spacing="12" styleClass="card">
                    <Label text="Create Auction"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                    <TextField fx:id="itemIdField"
                               promptText="Item ID"
                               styleClass="input"/>

                    <TextField fx:id="startTimeField"
                               promptText="Start time: 2026-06-06T10:00:00"
                               styleClass="input"/>

                    <TextField fx:id="endTimeField"
                               promptText="End time: 2026-06-06T12:00:00"
                               styleClass="input"/>

                    <TextField fx:id="currentPriceField"
                               promptText="Current price"
                               styleClass="input"/>

                    <Button text="Create Auction"
                            onAction="#handleCreateAuction"
                            prefWidth="300"
                            styleClass="primary-button"/>
                </VBox>

                <VBox spacing="12" styleClass="card">
                    <Label text="Auction Actions"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                    <TextField fx:id="auctionIdField"
                               promptText="Auction ID"
                               styleClass="input"/>

                    <Button text="Start Auction"
                            onAction="#handleStartAuction"
                            prefWidth="300"
                            styleClass="primary-button"/>

                    <Button text="Cancel Auction"
                            onAction="#handleCancelAuction"
                            prefWidth="300"
                            styleClass="danger-button"/>

                    <Button text="Mark As Paid"
                            onAction="#handleMarkAsPaid"
                            prefWidth="300"
                            styleClass="secondary-button"/>

                    <Button text="Close Expired Auctions"
                            onAction="#handleCloseExpiredAuctions"
                            prefWidth="300"
                            styleClass="secondary-button"/>
                </VBox>

            </VBox>

        </HBox>
    </center>

</BorderPane>