<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.auction.controller.AdminDashboardController">

    <children>
        <Label layoutX="220.0" layoutY="60.0"
               style="-fx-font-size: 24px; -fx-font-weight: bold;"
               text="Admin Dashboard" />

        <Label layoutX="190.0" layoutY="130.0"
               text="This is the admin management screen." />

        <Button layoutX="250.0" layoutY="220.0"
                mnemonicParsing="false"
                text="Logout"
                onAction="#handleLogout" />
    </children>
</AnchorPane>