<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefHeight="500.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.auction.AuctionListController">

    <children>
        <Label layoutY="15.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" alignment="CENTER"
               style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Auction List" />

        <Label fx:id="userInfoLabel" layoutY="55.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" alignment="CENTER_LEFT"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444444;" text="Thông tin người dùng..." />

        <TableView fx:id="auctionTableView" layoutX="50.0" layoutY="85.0" prefHeight="260.0" prefWidth="600.0"
                   AnchorPane.topAnchor="85.0" AnchorPane.bottomAnchor="90.0"
                   AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" reorderable="false" />
                <TableColumn fx:id="productNameColumn" text="Product Name" reorderable="false" />
                <TableColumn fx:id="priceColumn" text="Current Price" reorderable="false" />
                <TableColumn fx:id="statusColumn" text="Status" reorderable="false" />
            </columns>
        </TableView>

        <HBox spacing="10" alignment="CENTER_LEFT"
              AnchorPane.bottomAnchor="35.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0">
            <children>
                <Button text="View Detail" onAction="#handleViewDetail" />
                <Button fx:id="makeBidButton" text="Make Bid" onAction="#handleMakeBid" />
                <Button fx:id="depositButton" text="Deposit Money" onAction="#handleDepositMoney" />
                <Button fx:id="newSaleButton" text="New Sale" onAction="#handleNewSale" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #ff4d4d; -fx-text-fill: white; -fx-font-weight: bold;" />
            </children>
        </HBox>
    </children>
</AnchorPane>