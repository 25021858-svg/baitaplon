<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.AuctionDetailController"
            prefWidth="900"
            prefHeight="600"
            styleClass="root">

    <top>
        <VBox spacing="8" style="-fx-padding: 24;">
            <Label text="Auction Detail" styleClass="page-title"/>
            <Label fx:id="messageLabel" styleClass="error-label"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="20" style="-fx-padding: 0 24 24 24;">

            <VBox spacing="12" styleClass="card" prefWidth="560">
                <Label text="Auction Information"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <TextArea fx:id="auctionDetailTextArea"
                          editable="false"
                          wrapText="true"
                          prefHeight="380"/>
            </VBox>

            <VBox spacing="14" styleClass="card" prefWidth="270">
                <Label text="Place Your Bid"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <TextField fx:id="bidAmountField"
                           promptText="Bid amount"
                           styleClass="input"/>

                <Button text="Place Bid"
                        onAction="#handlePlaceBid"
                        prefWidth="220"
                        styleClass="primary-button"/>

                <Button text="Refresh"
                        onAction="#handleRefresh"
                        prefWidth="220"
                        styleClass="secondary-button"/>

                <Button text="Back"
                        onAction="#goBack"
                        prefWidth="220"
                        styleClass="secondary-button"/>
            </VBox>

        </HBox>
    </center>
</BorderPane>